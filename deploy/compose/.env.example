# Helmdeck Compose environment.
# Copy this file to .env and fill in real values, then:
#   docker compose -f deploy/compose/compose.yaml --env-file deploy/compose/.env up -d
#
# IMPORTANT: HELMDECK_JWT_SECRET must be at least 32 bytes (64 hex chars).
# Generate a fresh one with:
#   openssl rand -hex 32

HELMDECK_JWT_SECRET=replace-me-with-openssl-rand-hex-32-output

# GID of the host's "docker" group so the control-plane container can
# reach /var/run/docker.sock. Find with:
#   getent group docker | cut -d: -f3
# Default 999 works for Debian/Ubuntu. RHEL/Fedora often use a different
# GID — check before deploying.
HELMDECK_DOCKER_GID=999
